APP_ENV=dev
APP_BASE_URL=https://bot.example.com
APP_TIMEZONE=Asia/Tashkent
SPEECH_TEMP_DIR=/tmp/dental-bot-audio

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
ADMIN_TELEGRAM_CHAT_ID=
DEV_ADMIN_TG_ID=
BOT_MODE=polling

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dental_bot
POSTGRES_USER=dental_bot
POSTGRES_PASSWORD=password
# DATABASE_URL is auto-generated from POSTGRES_* variables above.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_LANGUAGE=ru
OPENAI_STT_RESPONSE_FORMAT=json
OPENAI_STT_TIMEOUT_MS=60000
OPENAI_STT_MAX_AUDIO_SIZE_MB=25
OPENAI_STT_PROMPT=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_TTS_FALLBACK_VOICE=cedar
OPENAI_TTS_RESPONSE_FORMAT=opus
OPENAI_TTS_TIMEOUT_MS=60000
OPENAI_TTS_MAX_CHARS=4096
OPENAI_TTS_SPEED=1.0
OPENAI_TTS_INSTRUCTIONS=

MUXLISA_API_KEY=
MUXLISA_BASE_URL=https://service.muxlisa.uz
MUXLISA_STT_TIMEOUT_MS=60000
MUXLISA_TTS_TIMEOUT_MS=60000
MUXLISA_MAX_AUDIO_SIZE_MB=5
MUXLISA_MAX_AUDIO_DURATION_SEC=60
MUXLISA_TTS_MAX_CHARS=512
MUXLISA_TTS_SPEAKER=0

YANDEX_SPEECHKIT_API_KEY=
YANDEX_TTS_BASE_URL=https://tts.api.cloud.yandex.net
YANDEX_TTS_MODEL=yandex-speechkit-tts-v1
YANDEX_TTS_LANGUAGE=ru-RU
YANDEX_TTS_VOICE=alena
YANDEX_TTS_EMOTION=good
YANDEX_TTS_SPEED=1.15
YANDEX_TTS_FORMAT=oggopus
YANDEX_TTS_TIMEOUT_MS=60000
YANDEX_TTS_MAX_CHARS=5000

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_ENDPOINT=https://westeurope.tts.speech.microsoft.com/cognitiveservices/v1
AZURE_TTS_LANGUAGE=ru-RU
AZURE_TTS_VOICE=ru-RU-SvetlanaNeural
AZURE_TTS_OUTPUT_FORMAT=ogg-24khz-16bit-mono-opus
AZURE_TTS_RATE=20%
AZURE_TTS_PITCH=
AZURE_TTS_RANGE=
AZURE_TTS_TIMEOUT_MS=60000
AZURE_TTS_MAX_CHARS=5000

GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/run/secrets/google_service_account.json

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dental-telegram-mvp

OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=dental-telegram-bot

TELEGRAM_OIDC_CLIENT_ID=
TELEGRAM_OIDC_CLIENT_SECRET=
TELEGRAM_OIDC_REDIRECT_URI=https://admin-uz-stomatolog.liven8n.site/admin/auth/telegram/callback
TELEGRAM_ADMIN_IDS=
SESSION_SECRET=
SESSION_COOKIE_NAME=uz_stomatolog_admin_session
SESSION_COOKIE_MAX_AGE_DAYS=30
