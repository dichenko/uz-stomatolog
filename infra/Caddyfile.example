# Copy this to /etc/caddy/Caddyfile or your Caddy config directory.
# Replace domains with actual ones. After saving, run: caddy reload

uz-stomatolog.liven8n.site {
    reverse_proxy 127.0.0.1:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        -Server
    }

    log {
        output file /var/log/caddy/uz-stomatolog-access.log
    }
}

admin-uz-stomatolog.liven8n.site {
    reverse_proxy 127.0.0.1:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        -Server
    }

    log {
        output file /var/log/caddy/admin-uz-stomatolog-access.log
    }
}
